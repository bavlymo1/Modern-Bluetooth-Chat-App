<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools">


    <!-- ✅ Android 12+ (API 31+) permissions -->
    <!-- Scan for nearby bluetooth devices (discovery). -->
    <uses-permission
            android:name="android.permission.BLUETOOTH_SCAN"
            android:usesPermissionFlags="neverForLocation"
            tools:targetApi="s" />

    <!-- Connect / communicate with already-paired devices (and also read bonded devices). -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Only needed if you make this device discoverable / advertise -->
    <!-- (e.g. using ACTION_REQUEST_DISCOVERABLE) -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- ✅ Legacy permissions (Android 11 and below). -->
    <!-- maxSdkVersion makes them only apply up to Android 11 -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />

    <!-- ✅ Discovery on Android 11 and below typically requires Location permission.
         If you DO NOT use scan results for location, Android 12+ can avoid location
         by using BLUETOOTH_SCAN + neverForLocation. -->
    <uses-permission
            android:name="android.permission.ACCESS_FINE_LOCATION"
            android:maxSdkVersion="30" />

    <!-- ✅ Hardware features (optional but recommended) -->
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />
<!--    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />-->

    <application
            android:allowBackup="true"
            android:dataExtractionRules="@xml/data_extraction_rules"
            android:fullBackupContent="@xml/backup_rules"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:supportsRtl="true"
            android:name=".MyApplication"
            android:theme="@style/Theme.Bluetooth_Chat_App">
        <activity
                android:name=".app.MainActivity"
                android:exported="true"
                android:theme="@style/Theme.Bluetooth_Chat_App">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>